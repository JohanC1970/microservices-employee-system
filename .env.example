RABBITMQ_HOST=message-broker
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASS=admin

# JWT — mínimo 32 caracteres para HMAC-SHA256
# Cambia este valor por una clave segura en producción
JWT_SECRET=tu-clave-secreta-aqui-minimo-32-caracteres
JWT_EXPIRATION_MS=86400000
JWT_RECOVERY_EXPIRATION_MS=3600000
